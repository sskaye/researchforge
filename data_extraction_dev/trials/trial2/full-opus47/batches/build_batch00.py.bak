#!/usr/bin/env python3
"""Build batch_pmc_00_results.csv from extracted mp/bp data."""
import csv
import os

OUT = "/sessions/practical-gifted-babbage/mnt/data_extraction_dev/Trial2-full-opus47/batches/batch_pmc_00_results.csv"
# Local writable version
LOCAL_OUT = "/Users/skaye/Claude/Skills/ResearchForge/data_extraction_dev/Trial2-full-opus47/batches/batch_pmc_00_results.csv"

ROWS = []
_nid = [0]

def add(compound_name, prop, vc, vmin, vmax, vraw, relation, dtype, source, source_url, eloc, equote, conv="", notes=""):
    _nid[0] += 1
    ROWS.append({
        'id': _nid[0],
        'verification_status': 'pending_verification',
        'compound_name': compound_name,
        'compound_smiles': '',
        'property': prop,
        'value_celsius': vc,
        'value_celsius_min': vmin,
        'value_celsius_max': vmax,
        'value_raw': vraw,
        'relation': relation,
        'data_type': dtype,
        'source': source,
        'source_url': source_url,
        'evidence_location': eloc,
        'evidence_quote': equote,
        'conversion_arithmetic': conv,
        'notes': notes,
    })

